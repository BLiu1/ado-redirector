[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "regexSubstitution": "https://dev.azure.com/\\1/\\2"
      }
    },
    "condition": {
      "regexFilter": "^https?://([^.]+)\\.visualstudio\\.com/(?:DefaultCollection/)?(.*)",
      "excludedRequestDomains": [
        "code.visualstudio.com",
        "developercommunity.visualstudio.com",
        "marketplace.visualstudio.com",
        "my.visualstudio.com",
        "vssps.visualstudio.com",
        "vsstatus.visualstudio.com"
      ],
      "resourceTypes": [
        "main_frame",
        "sub_frame"
      ]
    }
  },
  {
    "id": 2,
    "priority": 2,
    "action": {
      "type": "redirect",
      "redirect": {
        "transform": { "host": "aex.dev.azure.com" }
      }
    },
    "condition": {
      "requestDomains": ["app.vsaex.visualstudio.com"],
      "resourceTypes": [
        "main_frame",
        "sub_frame"
      ]
    }
  }
]
